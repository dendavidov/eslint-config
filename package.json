{
  "name": "@dendavidov/eslint-config",
  "version": "2.4.0",
  "description": "ESLint flat config for TypeScript/Node.js projects, supporting Node.js 24.x.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "license": "MIT",
  "scripts": {
    "test": "node scripts/verify-node-pins.cjs && NODE_OPTIONS=--experimental-vm-modules jest --watchAll=false",
    "format": "prettier --write .",
    "format:check": "prettier --check ./src",
    "lint": "eslint .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "author": "Denis Davydov mail@dendavidov.com",
  "repository": {
    "type": "git",
    "url": "git@github.com:dendavidov/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/dendavidov/eslint-config/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "src/index.js",
    "src/index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-security": "^4.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.2"
  }
}
